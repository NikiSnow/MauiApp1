        text-align: center;
        padding: 20px;
    }

    h1 {
        font-size: 48px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }

    button {
        background-color: #ff6b6b;
        color: white;
        border: none;
        padding: 12px 24px;
        font-size: 18px;
        border-radius: 25px;
        cursor: pointer;
        margin-top: 20px;
        transition: transform 0.2s;
    }

        button:hover {
            transform: scale(1.05);
            background-color: #ff5252;
        }

    p {
        font-size: 24px;
        font-weight: bold;
    }
    button {
